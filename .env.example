# Formspree form ID for the contact form.
# Get yours at https://formspree.io — create a form and add contact@zappisoft.com as the recipient.
# Then copy the form ID from the form URL (e.g. formspree.io/f/YOUR_ID).
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_form_id

# Google Analytics 4 Measurement ID (optional).
# Get yours at https://analytics.google.com — Admin → Data Streams → your web stream.
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
